# Copy this file to .env and customise for your environment.
# .env is gitignored — never commit real values.

# ── Upload / cleanup ──────────────────────────────────────────────────────────
MAX_UPLOAD_MB=200
CLEANUP_TEMP_AFTER_SECONDS=300
# Set true on dev to keep failed conversion workdirs in tmp_failed/ for debugging.
# Leave false on production — workdirs are deleted immediately on failure.
RETAIN_FAILED_FILES=false

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# Set OTEL_ENABLED=true to activate traces and metrics export.
# Requires OTEL_EXPORTER_OTLP_ENDPOINT to point at a running collector.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=u1convert

# ── Observability hosts ───────────────────────────────────────────────────────
# Hostnames for your Loki / OTel collector stack (used by Promtail and OTel export).
OTEL_HOST=otel.example.com
LOKI_HOST=logs.example.com
LOKI_URL=https://logs.example.com

# ── Frontend build ────────────────────────────────────────────────────────────
# Injected at Docker build time — sets canonical URL and og:url in index.html.
# Must be set before running: docker compose build
VITE_SITE_URL=https://your-domain.com

# ── Runtime domain ────────────────────────────────────────────────────────────
# Used by FastAPI for robots.txt and sitemap.xml. Should match the public hostname.
DOMAINHOST=your-domain.com

# ── Analytics (optional) ──────────────────────────────────────────────────────
# Leave empty to disable Google Analytics entirely. When set, the gtag script
# loads from googletagmanager.com and the CSP + privacy page expand accordingly.
# Requires `docker compose up --build` to apply (baked into the frontend bundle).
GA_MEASUREMENT_ID=

# Cloudflare Web Analytics (RUM) beacon token. Leave empty to disable.
# To get a token: Cloudflare dashboard → Web Analytics → your site →
# "Enable with JS Snippet installation" → copy the token from the snippet's
# data-cf-beacon='{"token":"…"}' attribute. Manual mode avoids the inline-script
# CSP violation that auto-injection causes.
CF_BEACON_TOKEN=
